{
  "name": "@agentschitzo/app",
  "version": "1.0.0",
  "description": "Telegram automation service for Codex over Telegram.",
  "main": "src/main.ts",
  "scripts": {
    "dev": "node ../node_modules/tsx/dist/cli.mjs src/main.ts",
    "start": "node ../node_modules/tsx/dist/cli.mjs src/main.ts",
    "typecheck": "node ../node_modules/typescript/bin/tsc --noEmit -p tsconfig.json",
    "test": "node --experimental-vm-modules ../node_modules/jest/bin/jest.js --config jest.config.js --runInBand --coverage --coverageReporters=json-summary --coverageReporters=text-summary",
    "test:hook": "node --experimental-vm-modules ../node_modules/jest/bin/jest.js --config jest.config.js --runInBand",
    "lint": "npm run lint:node && npm --prefix ../web run lint",
    "lint:node": "node ../node_modules/eslint/bin/eslint.js --config eslint.config.js .",
    "lint:fix": "npm run lint:fix:node && npm --prefix ../web run lint -- --fix",
    "lint:fix:node": "node ../node_modules/eslint/bin/eslint.js --config eslint.config.js . --fix",
    "format": "node ../node_modules/prettier/bin/prettier.cjs . --write",
    "format:check": "node ../node_modules/prettier/bin/prettier.cjs . --check",
    "commitlint": "../node_modules/.bin/commitlint --config commitlint.config.cjs --edit",
    "prepare": "node ./prepare-husky.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/better-sqlite3": "7.6.13",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/ws": "8.5.14",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "prettier": "^3.8.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  },
  "dependencies": {
    "@types/multer": "^1.4.12",
    "better-sqlite3": "11.10.0",
    "cors": "2.8.5",
    "esprima": "^4.0.1",
    "express": "4.21.2",
    "langfuse": "3.38.20",
    "multer": "^1.4.5-lts.1",
    "openai": "^6.34.0",
    "ws": "8.18.2"
  }
}
