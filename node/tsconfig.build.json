{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "../dist",
    "rootDir": "..",
    "sourceMap": false,
    "declaration": false,
    "rewriteRelativeImportExtensions": true
  },
  "include": [
    "src/**/*.ts",
    "scripts/**/*.ts"
  ],
  "exclude": ["tests", "../coverage", "../dist", "../node_modules"]
}
