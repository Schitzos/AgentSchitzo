{
  "name": "@agentschitzo/app",
  "version": "1.0.0",
  "description": "Telegram automation service for Codex over Telegram.",
  "main": "dist/telegram-listener.js",
  "bin": {
    "agentSchitzo": "./bin/agentSchitzo.js"
  },
  "exports": {
    "./models/*": {
      "types": "./models/*.ts",
      "default": "./dist/models/*.js"
    },
    "./telegram/*": {
      "types": "./telegram/*.ts",
      "default": "./dist/telegram/*.js"
    },
    "./types/*": {
      "types": "./types/*.ts",
      "default": "./dist/types/*.js"
    },
    "./utils/*": {
      "types": "./utils/*.ts",
      "default": "./dist/utils/*.js"
    },
    "./telegram-listener": {
      "types": "./telegram-listener.ts",
      "default": "./dist/telegram-listener.js"
    }
  },
  "scripts": {
    "dev": "tsx telegram-listener.ts",
    "start": "node dist/telegram-listener.js",
    "build": "npx rimraf dist && npm run lint && npm test && npm run typecheck && npm run build-dist",
    "build-dist": "node --experimental-strip-types ./utils/build-dist.ts",
    "start:dist": "npm --prefix dist start",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand --coverage --coverageReporters=json-summary --coverageReporters=text-summary",
    "test:hook": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "commitlint": "commitlint --edit",
    "prepare": "node ./prepare-husky.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "prettier": "^3.8.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  },
  "dependencies": {
    "esprima": "^4.0.1",
    "openai": "^6.34.0"
  }
}
